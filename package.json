{
  "name": "@wienerberliner/pi-arxiv",
  "version": "0.1.0",
  "description": "arXiv search, lookup, and Markdown fetching tools for pi.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "arxiv",
    "markdown",
    "papers"
  ],
  "license": "MIT",
  "type": "module",
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fast-xml-parser": "^5.2.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "@types/node": "latest",
    "typebox": "latest",
    "typescript": "latest"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dasomji/pi-arxiv.git"
  },
  "bugs": {
    "url": "https://github.com/dasomji/pi-arxiv/issues"
  },
  "homepage": "https://github.com/dasomji/pi-arxiv#readme"
}
